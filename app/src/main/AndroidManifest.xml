<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions for Nostr WebSockets and IPFS -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Advertiser GPS Location for generating map links -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Background Execution & WorkManager for listening to Ad Relays -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Notifications for alerting Users about new Local Deals -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Allows the Ad Popup Card and Error Card to show over other apps -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".AdNostrApplication"
        android:allowBackup="true"
        android:icon="@drawable/adnostr"
        android:label="@string/app_name"
        android:roundIcon="@drawable/adnostr"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdNostr"
        tools:targetApi="31">

        <!-- Splash Screen: Silently generates Nostr Keys in background -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The Fork: Asks user if they are an Advertiser or standard User -->
        <activity
            android:name=".RoleSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

        <!-- Main App Interface: Hosts bottom navigation & fragments -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

        <!-- The Ad Popup Overlay -->
        <activity
            android:name=".AdPopupActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.AdNostr.Transparent" />

        <!-- CRITICAL: The Global Error Display Activity -->
        <!-- Running in a separate process so it survives the main app crash -->
        <activity
            android:name=".ErrorDisplayActivity"
            android:process=":error_handler"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

    </application>

</manifest>