<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.adnostr.app">

    <!-- Network permissions for Nostr WebSockets and IPFS Gateways -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Advertiser GPS Location for generating shop map links -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- STORAGE PERMISSIONS: Required to select and upload images to IPFS -->
    <!-- For devices running Android 12 (API 32) and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    <!-- For devices running Android 13 (API 33) and above -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Background Execution & WorkManager for listening to Ad Relays -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Notifications for alerting Users about new Local Deals (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Allows the Ad Popup Card and Error Card to show over other apps/lock screen -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".AdNostrApplication"
        android:allowBackup="true"
        android:icon="@drawable/adnostr"
        android:label="@string/app_name"
        android:roundIcon="@drawable/adnostr"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdNostr"
        tools:targetApi="31">

        <!-- Splash Screen: Silently generates Nostr Keys and routes the user -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding: Path selection for User vs Advertiser -->
        <activity
            android:name=".RoleSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

        <!-- Main Interface: Hosts Dashboards, Ad Creation, and Settings -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

        <!-- Ad Delivery Card: Displays the IPFS swipe gallery popup -->
        <activity
            android:name=".AdPopupActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.AdNostr.Transparent" />

        <!-- CRITICAL: The Global Error Display Activity -->
        <!-- Runs in a separate process to capture crashes from the main process -->
        <activity
            android:name=".ErrorDisplayActivity"
            android:process=":error_handler"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.AdNostr.NoActionBar" />

    </application>

</manifest>