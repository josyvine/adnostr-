<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/hfs_card_black"
    android:scrollbars="none">

    <!-- 
        ADNOSTR CONSOLIDATED APPEARANCE ENGINE
        This layout manages both the visual skin (Theme) and the structural logic (Template).
        Designed for high-contrast visibility and professional UX.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HEADER SECTION -->
        <TextView
            android:id="@+id/tvAppearanceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance &amp; Structure"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure how advertisements and product details are presented globally."
            android:textColor="@color/hfs_text_grey"
            android:textSize="13sp"
            android:layout_marginBottom="24dp" />

        <!-- SECTION 1: APP THEME (DAY/NIGHT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cmd_switch"
                app:tint="@color/hfs_active_blue"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Day Mode"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDayMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/hfs_border_grey"
            android:layout_marginBottom="24dp" />

        <!-- SECTION 2: SPECIFICATION TEMPLATE MODE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_report"
                    app:tint="@color/hfs_active_green"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Specification Structure"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose between a flat grid or organized sliding drawers."
                android:textColor="@color/hfs_text_grey"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="36dp"/>

            <!-- RADIO GROUP FOR TEMPLATE SELECTION -->
            <RadioGroup
                android:id="@+id/rgTemplateMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp">

                <!-- OPTION 1: NORMAL MODE -->
                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbTemplateNormal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Normal Template (Flat Grid)"
                    android:textColor="@color/white"
                    android:buttonTint="@color/hfs_active_blue"
                    android:paddingStart="12dp"
                    android:layout_marginBottom="8dp"/>

                <!-- OPTION 2: SLIDER MODE -->
                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbTemplateSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Slider Template (Accordion)"
                    android:textColor="@color/white"
                    android:buttonTint="@color/hfs_active_green"
                    android:paddingStart="12dp" />
            </RadioGroup>
        </LinearLayout>

        <!-- FOOTER ACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelTheme"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLOSE"
                android:textColor="@color/hfs_text_grey"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveAppearance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APPLY CHANGES"
                android:textColor="@color/white"
                android:backgroundTint="@color/hfs_active_blue"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>