<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@color/app_card_background">

    <!-- 
        ADNOSTR CONSOLIDATED APPEARANCE & STRUCTURE ENGINE
        This layout manages both the visual skin (Theme) and the structural logic (Template).
        Uses original project resources to ensure zero build errors.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- DIALOG HEADER -->
        <TextView
            android:id="@+id/tvAppearanceTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance &amp; Structure"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure global visual skin and data presentation."
            android:textSize="13sp"
            android:textColor="@color/app_text_muted"
            android:layout_marginTop="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/app_border"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <!-- SECTION 1: APP THEME (DAY/NIGHT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/invert_colors_24px"
                app:tint="@color/hfs_active_blue" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Mode"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="White background / Black text"
                    android:textSize="12sp"
                    android:textColor="@color/app_text_muted" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDayMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/hfs_active_blue"
                app:trackTint="@color/app_border" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/app_border"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- SECTION 2: SPECIFICATION TEMPLATE MODE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_nav_report"
                    app:tint="@color/hfs_active_green" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Specification Structure"
                    android:textColor="@color/app_text_main"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose how technical details are rendered in the dashboard and viewer."
                android:textColor="@color/app_text_muted"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="44dp"/>

            <!-- RADIO GROUP FOR TEMPLATE SELECTION -->
            <RadioGroup
                android:id="@+id/rgTemplateMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbTemplateNormal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Normal Template (Flat Grid)"
                    android:textColor="@color/app_text_main"
                    android:buttonTint="@color/hfs_active_blue"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbTemplateSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Slider Template (Accordion)"
                    android:textColor="@color/app_text_main"
                    android:buttonTint="@color/hfs_active_green"
                    android:textSize="14sp" />
            </RadioGroup>
        </LinearLayout>

        <!-- DESCRIPTION NOTE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Note: Structural changes apply instantly. The Slider Template segregates technical specifications into dynamic accordion sections based on your product data."
            android:textSize="11sp"
            android:alpha="0.7"
            android:textColor="@color/app_text_muted" />

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="32dp">

            <Button
                android:id="@+id/btnCancelTheme"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLOSE"
                android:textColor="@color/hfs_active_blue"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>