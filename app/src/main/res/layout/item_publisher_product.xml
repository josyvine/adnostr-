<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cvPublisherCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#333333"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- PRODUCT IMAGE PLACEHOLDER -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProductThumb"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="#121212"
            android:padding="16dp"
            android:src="@drawable/ic_nav_publisher"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
            app:tint="#444444" />

        <!-- SELECTION CHECKMARK OVERLAY (New Enhancement) -->
        <ImageView
            android:id="@+id/ivSelectionCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_circle_blue"
            android:padding="4dp"
            android:src="@android:drawable/checkbox_on_background"
            android:visibility="gone"
            app:layout_constraintCircle="@+id/ivProductThumb"
            app:layout_constraintCircleAngle="45"
            app:layout_constraintCircleRadius="40dp"
            app:layout_constraintEnd_toEndOf="@+id/ivProductThumb"
            app:layout_constraintTop_toTopOf="@+id/ivProductThumb"
            app:tint="#FFFFFF"
            tools:visibility="visible" />

        <!-- PRODUCT CONTENT AREA -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/llPriceBadge"
            app:layout_constraintStart_toEndOf="@+id/ivProductThumb"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvProductTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Premium Product Title"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProductStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="● LIVE ON NOSTR"
                android:textColor="#4CAF50"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvProductPointer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="middle"
                android:maxLines="1"
                android:text="Kind: 30005 Pointer"
                android:textColor="#666666"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- PRICE AREA (End Aligned) -->
        <LinearLayout
            android:id="@+id/llPriceBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 0"
                android:textColor="#FF9800"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:alpha="0.2"
                android:src="@android:drawable/ic_media_play"
                app:tint="#FFFFFF" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>