<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#2C2C2C"
    app:cardCornerRadius="12dp"
    app:cardElevation="16dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- BOLD BUTTON -->
        <ImageButton
            android:id="@+id/btnPopupBold"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Bold"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#FFFFFF" />

        <!-- SEPARATOR -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="#555555" />

        <!-- ITALIC BUTTON -->
        <ImageButton
            android:id="@+id/btnPopupItalic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Italic"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#FFFFFF" />

        <!-- SEPARATOR -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="#555555" />

        <!-- UNDERLINE BUTTON -->
        <ImageButton
            android:id="@+id/btnPopupUnderline"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Underline"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="#FFFFFF" />

    </LinearLayout>

</androidx.cardview.widget.CardView>