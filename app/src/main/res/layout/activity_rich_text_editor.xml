<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- TOP NAVIGATION & ACTION BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clEditorHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1E1E1E"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnCancelEditor"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rich Text Editor"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnSaveRichText"
            app:layout_constraintStart_toEndOf="@+id/btnCancelEditor"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveRichText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#4CAF50"
            android:text="DONE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MAIN TEXT CANVAS -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/hsvControlPanel"
        app:layout_constraintTop_toBottomOf="@id/clEditorHeader">

        <!-- FIXED: Added inputType and gravity to ensure Spans render correctly and 
             formatting stays visible while typing. -->
        <EditText
            android:id="@+id/etRichContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:gravity="top|start"
            android:hint="Start typing your professional ad description..."
            android:inputType="textMultiLine|textNoSuggestions|textLongMessage"
            android:padding="24dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#444444"
            android:textSize="16sp" />

    </androidx.core.widget.NestedScrollView>

    <!-- MODERN CONTROL ASSISTANCE PANEL (Bottom Formatting Toolbar) -->
    <!-- FIXED: Ensured IDs match Java listeners and optimized touch targets 
         to prevent "Placeholder" behavior. -->
    <HorizontalScrollView
        android:id="@+id/hsvControlPanel"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1E1E1E"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <!-- ALIGNMENT GROUP -->
            <ImageButton
                android:id="@+id/btnAlignLeft"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Align Left"
                android:src="@android:drawable/ic_menu_sort_alphabetically"
                app:tint="#B0B0B0" />

            <ImageButton
                android:id="@+id/btnAlignCenter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Align Center"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#B0B0B0" />

            <ImageButton
                android:id="@+id/btnAlignRight"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Align Right"
                android:rotation="180"
                android:src="@android:drawable/ic_menu_sort_alphabetically"
                app:tint="#B0B0B0" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#333333" />

            <!-- LIST STYLES -->
            <ImageButton
                android:id="@+id/btnBulletList"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bullet List"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#B0B0B0" />

            <ImageButton
                android:id="@+id/btnNumberList"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Number List"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#B0B0B0" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#333333" />

            <!-- TEXT FORMATTING -->
            <ImageButton
                android:id="@+id/btnBold"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bold"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#B0B0B0" />

            <ImageButton
                android:id="@+id/btnItalic"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Italic"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#B0B0B0" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#333333" />

            <!-- SPECIALIZED SUB-HEADING TOOL -->
            <!-- FIXED: Ensured H2 button is clickable and matches Java RelativeSizeSpan logic. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubHeading"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="48dp"
                android:text="H2"
                android:textColor="#2196F3"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="#333333" />

            <!-- FONT SIZE & COLOR -->
            <ImageButton
                android:id="@+id/btnFontSize"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Font Size"
                android:src="@android:drawable/ic_menu_zoom"
                app:tint="#B0B0B0" />

            <ImageButton
                android:id="@+id/btnTextColor"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Text Color"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#4CAF50" />

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>