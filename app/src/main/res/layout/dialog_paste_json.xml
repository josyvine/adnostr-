<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/paste_json_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Paste your backup JSON string below to restore your identity and settings."
            android:textColor="#BDBDBD"
            android:textSize="14sp" />

        <!-- High-Contrast Monospace Input Box -->
        <EditText
            android:id="@+id/etPasteJsonInput"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            android:background="#2A2A2A"
            android:gravity="top|start"
            android:hint="@string/paste_json_hint"
            android:inputType="textMultiLine"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:typeface="monospace" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <!-- Button: Clear -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeletePasteInput"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="@string/btn_clear_input"
                android:textColor="#2196F3"
                app:cornerRadius="8dp"
                app:strokeColor="#2196F3" />

            <!-- Button: Verify & Restore -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerifyAndRestore"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1.5"
                android:text="@string/btn_verify_restore"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="#4CAF50"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnCancelPaste"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:padding="8dp"
            android:text="CANCEL"
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>