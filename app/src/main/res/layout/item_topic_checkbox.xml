<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp"
    android:background="#121212">

    <!-- TOPIC NAME -->
    <TextView
        android:id="@+id/tvTopicName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Mobiles &amp; Tech"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/cbTopicSelection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- SELECTION CHECKBOX -->
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbTopicSelection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:buttonTint="#2196F3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- DIVIDER LINE -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cbTopicSelection" />

</androidx.constraintlayout.widget.ConstraintLayout>