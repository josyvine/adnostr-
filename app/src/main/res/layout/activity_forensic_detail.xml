<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".ForensicDetailActivity">

    <!-- TOP NAVIGATION BAR -->
    <LinearLayout
        android:id="@+id/llForensicHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#121212"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cmd_reset"
            android:rotation="90"
            app:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAJAJ"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Models Seeding"
                android:textColor="#FF6A00"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />

        </LinearLayout>

    </LinearLayout>

    <!-- GOVERNANCE BAR (SELECT ALL) -->
    <LinearLayout
        android:id="@+id/llGovernanceBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/llForensicHeader">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Individual Entry List"
            android:textColor="#BDBDBD"
            android:textSize="13sp"
            android:textStyle="italic" />

        <CheckBox
            android:id="@+id/cbSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textColor="#FFFFFF"
            android:buttonTint="#FF6A00"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- SCROLLABLE VALUE LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvValueList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/llGovernanceBar"
        app:layout_constraintBottom_toTopOf="@id/btnNukeSelected" />

    <!-- PRIMARY ACTION BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNukeSelected"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="PURGE SELECTED (0)"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#FF3B30"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>