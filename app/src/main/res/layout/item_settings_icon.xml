<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- THE SQUARE APP ICON CONTAINER -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSettingIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:rippleColor="#40FFFFFF"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- THE VECTOR ICON -->
            <ImageView
                android:id="@+id/ivSettingIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:contentDescription="Setting Icon"
                app:tint="#FFFFFF"
                tools:src="@android:drawable/ic_menu_preferences" />

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- THE ICON LABEL -->
    <TextView
        android:id="@+id/tvSettingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        tools:text="Profile" />

</LinearLayout> 