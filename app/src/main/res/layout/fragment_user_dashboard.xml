<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- CONNECTION STATUS BAR -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvStatusHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Green Status Dot -->
            <ImageView
                android:id="@+id/ivStatusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="10dp"
                android:src="@android:drawable/presence_online"
                app:tint="#4CAF50" />

            <TextView
                android:id="@+id/tvRelayStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connected to 34 Relays"
                android:textColor="#B0B0B0"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- INSTRUCTIONAL TEXT -->
    <TextView
        android:id="@+id/tvDiscoveryHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="What are you interested in?"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cvStatusHeader" />

    <TextView
        android:id="@+id/tvDiscoverySub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Select hashtags to receive relevant decentralized local deals via popup notifications."
        android:textColor="#888888"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvDiscoveryHeader" />

    <!-- HASHTAG INTEREST GRID -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHashtags"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/btnEditInterests"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvDiscoverySub"
        tools:listitem="@layout/item_hashtag" />

    <!-- ACTION BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEditInterests"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#2196F3"
        android:text="START RECEIVING ADS"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- EMPTY STATE VIEW (Hidden by default) -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for local deals..."
        android:textColor="#444444"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/rvHashtags"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/rvHashtags" />

</androidx.constraintlayout.widget.ConstraintLayout>