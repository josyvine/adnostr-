<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Identity Passport"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Your AdNostr account is decentralized. It is not stored on a server. You can download a backup to secure your account or move it to another device."
            android:textColor="#BDBDBD"
            android:textSize="14sp" />

        <!-- Warning Label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#33FF5252"
            android:gravity="center"
            android:padding="8dp"
            android:text="WARNING: This file contains your Private Key. Do not share it with anyone."
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Button: Export / Download -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadPassport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="DOWNLOAD BACKUP"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#2196F3"
            app:cornerRadius="8dp" />

        <!-- Button: Import / Restore -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestorePassport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="RESTORE FROM BACKUP"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/btnCloseBackup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:padding="8dp"
            android:text="CANCEL"
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>