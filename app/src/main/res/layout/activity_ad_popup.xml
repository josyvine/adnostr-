<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000"
    android:padding="24dp">

    <!-- THE AD CARD CONTAINER -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvAdPopup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AD IMAGE COVER (IPFS Loaded via Coil) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivAdCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    tools:srcCompat="@android:drawable/ic_menu_gallery" />
                
                <!-- Close Button Overlay -->
                <ImageButton
                    android:id="@+id/btnCloseAd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end|top"
                    android:layout_margin="12dp"
                    android:background="@drawable/bg_circle_dark"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>

            <!-- AD TEXT CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvPopupTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Ad Title Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvPopupDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Loading ad details from decentralized network..."
                    android:textColor="#B0B0B0"
                    android:textSize="14sp" />

                <!-- DYNAMIC ACTION BUTTONS CONTAINER -->
                <!-- Only visible buttons will be shown via AdPopupActivity.java -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/flexActionButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:flexWrap="wrap"
                    app:justifyContent="flex_start">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnActionWhatsapp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="WhatsApp"
                        android:textColor="#4CAF50"
                        android:visibility="gone"
                        app:icon="@android:drawable/ic_menu_send"
                        app:iconTint="#4CAF50"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnActionMap"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Open Map"
                        android:textColor="#2196F3"
                        android:visibility="gone"
                        app:icon="@android:drawable/ic_dialog_map"
                        app:iconTint="#2196F3"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnActionWebsite"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Visit Web"
                        android:textColor="#FFFFFF"
                        android:visibility="gone"
                        app:icon="@android:drawable/ic_menu_browser"
                        app:iconTint="#FFFFFF"
                        tools:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnActionCall"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Call Now"
                        android:textColor="#FF9800"
                        android:visibility="gone"
                        app:icon="@android:drawable/ic_menu_call"
                        app:iconTint="#FF9800"
                        tools:visibility="visible" />

                </com.google.android.flexbox.FlexboxLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>