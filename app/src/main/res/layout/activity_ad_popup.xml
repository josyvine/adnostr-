<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    tools:context=".AdPopupActivity">

    <!-- SEMI-TRANSPARENT CLICKABLE BACKGROUND (Closes ad if tapped outside) -->
    <View
        android:id="@+id/viewBackgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- MAIN AD CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvAdContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="#121212"
        app:cardCornerRadius="24dp"
        app:cardElevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#22FFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- IMAGE SLIDER AREA -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="320dp">

                <!-- FIXED: ViewPager2 with black background to prevent white gaps -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpAdImages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#000000"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <!-- Fallback single image view -->
                <ImageView
                    android:id="@+id/ivAdCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    tools:src="@android:drawable/ic_menu_gallery" />

                <!-- Close Button (Top Right) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCloseAd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_margin="16dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#80000000"
                    app:cornerRadius="18dp"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#FFFFFF"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- NEW: Zoom Button (Top Left) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnZoomImage"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_margin="16dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#80000000"
                    app:cornerRadius="18dp"
                    app:icon="@android:drawable/ic_menu_zoom"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#FFFFFF"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- MODERN SWIPE INDICATOR (E-commerce Style Overlay) -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabDots"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginBottom="12dp"
                    android:background="@android:color/transparent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tabBackground="@drawable/modern_dot_selector"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="10dp"
                    app:tabRippleColor="@null" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CONTENT AREA -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="320dp"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvPopupTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        tools:text="Ad Title Here" />

                    <TextView
                        android:id="@+id/tvPopupDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="6dp"
                        android:textColor="#BDBDBD"
                        android:textSize="16sp"
                        tools:text="Detailed description of the ad broadcast goes here." />

                    <!-- ACTION BUTTONS -->
                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/flexActionButtons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        app:flexWrap="wrap"
                        app:justifyContent="flex_start">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnActionWhatsapp"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="10dp"
                            android:text="WhatsApp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:backgroundTint="#25D366"
                            app:cornerRadius="14dp"
                            app:icon="@android:drawable/stat_sys_speakerphone"
                            tools:visibility="visible" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnActionMap"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="10dp"
                            android:text="Directions"
                            android:textAllCaps="false"
                            android:visibility="gone"
                            app:backgroundTint="#4285F4"
                            app:cornerRadius="14dp"
                            app:icon="@android:drawable/ic_dialog_map"
                            tools:visibility="visible" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnActionWebsite"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_marginBottom="10dp"
                            android:text="Website"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:visibility="gone"
                            app:cornerRadius="14dp"
                            app:strokeColor="#FFFFFF"
                            tools:visibility="visible" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnActionCall"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:text="Call Now"
                            android:textAllCaps="false"
                            android:visibility="gone"
                            app:backgroundTint="#F57C00"
                            app:cornerRadius="14dp"
                            app:icon="@android:drawable/ic_menu_call"
                            tools:visibility="visible" />

                    </com.google.android.flexbox.FlexboxLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>