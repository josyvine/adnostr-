<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    tools:context=".AdPopupActivity">

    <!-- SEMI-TRANSPARENT CLICKABLE BACKGROUND (Closes ad if tapped outside) -->
    <View
        android:id="@+id/viewBackgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true" />

    <!-- MAIN AD CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvAdContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="#121212"
        app:cardCornerRadius="24dp"
        app:cardElevation="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#22FFFFFF"
        app:strokeWidth="1dp">

        <!-- GLITCH FIX: Switched to ConstraintLayout to enable Vertical Chaining.
             This forces the UI to measure the text area immediately. -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- BRANDING BAR -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llTopBrandingBar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvLogoWrapper"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardBackgroundColor="#333333"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/ivAdLogo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvVerifiedBanner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="✔ Verified"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cvLogoWrapper"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- IMAGE SLIDER AREA -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clImageArea"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                app:layout_constraintTop_toBottomOf="@id/llTopBrandingBar">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpAdImages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#000000" />

                <ImageView
                    android:id="@+id/ivAdCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:visibility="gone"
                    tools:src="@android:drawable/ic_menu_gallery" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCloseAd"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="12dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#80000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#FFFFFF"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnZoomImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="12dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="#80000000"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_zoom"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconTint="#FFFFFF"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabDots"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginBottom="8dp"
                    android:background="@android:color/transparent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:tabBackground="@drawable/modern_dot_selector"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabMaxWidth="8dp"
                    app:tabRippleColor="@null" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- GLITCH FIX: vpAdText now uses match_constraint (0dp) with a minHeight.
                 It is anchored to the Image Area and the Read More button. -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpAdText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:minHeight="110dp"
                android:padding="20dp"
                app:layout_constraintHeight_min="110dp"
                app:layout_constraintTop_toBottomOf="@id/clImageArea"
                app:layout_constraintBottom_toTopOf="@+id/tvReadMore" />

            <TextView
                android:id="@+id/tvReadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="8dp"
                android:padding="4dp"
                android:text="Read More..."
                android:textColor="#2196F3"
                android:textSize="13sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@+id/llIconActions"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/vpAdText"
                tools:visibility="visible" />

            <!-- ACTION BAR -->
            <LinearLayout
                android:id="@+id/llIconActions"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvReadMore">

                <ImageView
                    android:id="@+id/ivActionWhatsapp"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/stat_sys_speakerphone"
                    android:visibility="gone"
                    app:tint="#25D366"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/ivActionCall"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/ic_menu_call"
                    android:visibility="gone"
                    app:tint="#FFFFFF"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/ivActionInstagram"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/ic_menu_camera"
                    android:visibility="gone"
                    app:tint="#E4405F"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/ivActionWebsite"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/ic_menu_share"
                    android:visibility="gone"
                    app:tint="#FFFFFF"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/ivActionMap"
                    android:layout_width="0dp"
                    android:layout_height="24dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/ic_dialog_map"
                    android:visibility="gone"
                    app:tint="#4285F4"
                    tools:visibility="visible" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>