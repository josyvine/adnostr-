<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme for Night Mode (Dark Theme) -->
    <style name="Theme.CloudNest" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@android:color/white</item>

        <!-- Secondary brand colors -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@android:color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/app_status_bar</item>
        <!-- Logic: Ensures status bar icons are light for the dark background -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Surface and Background colors - Required for Material Components -->
        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorOnBackground">@color/app_text_main</item>
        <item name="colorSurface">@color/app_card_background</item>
        <item name="colorOnSurface">@color/app_text_main</item>
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>

        <!-- Standard Text Colors -->
        <item name="android:textColorPrimary">@color/app_text_main</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item>

        <!-- Toolbar Icon & Menu Colors -->
        <item name="colorControlNormal">@android:color/white</item>
        <item name="actionMenuTextColor">@android:color/white</item>
    </style>

    <!-- Theme for Splash Screen (No Action Bar) -->
    <style name="Theme.CloudNest.NoActionBar" parent="Theme.CloudNest">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- ================================================================= -->
    <!-- NEW: ADNOSTR THEME MAPPING (REQUIRED BY UPDATED JAVA FILES)       -->
    <!-- ================================================================= -->

    <style name="Theme.AdNostr" parent="Theme.CloudNest">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_status_bar</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.AdNostr.NoActionBar" parent="Theme.CloudNest.NoActionBar">
        <!-- Inherits from CloudNest Dark variant -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <!-- Night variant for Dialogs -->
    <style name="Theme.AdNostr.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/app_card_background</item>
        <item name="android:textColorPrimary">@color/app_text_main</item>
        <item name="colorAccent">#2196F3</item>
    </style>

</resources>