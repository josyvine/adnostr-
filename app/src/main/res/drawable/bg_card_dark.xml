<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Dark card background color matching our hfs_card_dark palette -->
    <solid android:color="#1E1E1E" />
    
    <!-- Rounded corners as specified in the UI design -->
    <corners android:radius="16dp" />
    
    <!-- Subtle border to help the card stand out against the #121212 background -->
    <stroke
        android:width="1dp"
        android:color="#333333" />
        
</shape>