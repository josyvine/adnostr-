<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    
    <!-- Semi-transparent dark background (Black with 60% alpha) -->
    <solid android:color="#99000000" />
    
    <!-- Standard size for the action button background -->
    <size
        android:width="40dp"
        android:height="40dp" />

    <!-- Optional: Subtle border to distinguish from very dark images -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
</shape>