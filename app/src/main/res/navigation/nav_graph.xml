<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_user_dashboard">

    <!-- USER PATH: Interest Selection & Background Monitor Status -->
    <fragment
        android:id="@+id/nav_user_dashboard"
        android:name="com.adnostr.app.UserDashboardFragment"
        android:label="My Interests"
        tools:layout="@layout/fragment_user_dashboard" />

    <!-- ADVERTISER PATH: Business Metrics & Active Ad Reach -->
    <fragment
        android:id="@+id/nav_advertiser_dashboard"
        android:name="com.adnostr.app.AdvDashboardFragment"
        android:label="Advertiser Stats"
        tools:layout="@layout/fragment_adv_dashboard" />

    <!-- ADVERTISER PATH: Ad Content Creation (IPFS & Maps) -->
    <fragment
        android:id="@+id/nav_create_ad"
        android:name="com.adnostr.app.CreateAdFragment"
        android:label="Broadcast New Ad"
        tools:layout="@layout/fragment_create_ad" />

    <!-- ADVERTISER PATH: Decentralized Relay Buying & Selling -->
    <fragment
        android:id="@+id/nav_relay_marketplace"
        android:name="com.adnostr.app.MarketplaceFragment"
        android:label="Relay Marketplace"
        tools:layout="@layout/fragment_marketplace" />

    <!-- SHARED PATH: Profile, Mode Switching, and Network Status -->
    <fragment
        android:id="@+id/nav_settings"
        android:name="com.adnostr.app.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>