<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Theme.AdNostr" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorPrimaryVariant">#1976D2</item>
        <item name="onPrimary">@color/white</item>
        <!-- Secondary brand colors -->
        <item name="colorSecondary">#4CAF50</item>
        <item name="colorSecondaryVariant">#388E3C</item>
        <item name="onSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">#121212</item>
        <!-- Customize your theme here -->
        <item name="android:windowBackground">#121212</item>
    </style>

    <!-- Full screen theme without Action Bar (Used for Splash and Main) -->
    <style name="Theme.AdNostr.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">#121212</item>
    </style>

    <!-- Transparent Popup Theme (Used for the Ad Popup Card) -->
    <style name="Theme.AdNostr.Transparent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <!-- Custom Dialog Style for Error Diagnostic and Reset Confirmation -->
    <style name="Theme.AdNostr.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@drawable/bg_card_dark</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorAccent">#2196F3</item>
    </style>

    <!-- Helper for Rounded Image Buttons -->
    <style name="bg_circle_dark">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>